#!/bin/bash
#
# Usage on mac:
# % /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/imotov/ohia/main/bootstrap)"
#
# Usage on linux:
# $ /bin/bash -c "$(wget -O-  https://raw.githubusercontent.com/imotov/ohia/main/bootstrap)"
#
# Piping into zsh doesn't work due to https://github.com/Homebrew/homebrew-core/issues/141712
#

set -e
OS=$(uname)
PROJECT_HOME="$HOME/Projects/imotov"
OHIA_HOME="$PROJECT_HOME/ohia"

if [[ $OS == "Darwin" ]]; then
    # Install Homebrew if needed, this should install command line tools with git
    if ! [ "$(command -v brew)" ]; then
        echo "Checking sudo..."
        sudo echo "sudo have been acquired"
         NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
    MAC_PACKAGES=(
        exiftool
        jq
        tree
        xz
    )
    brew update
    MISSING_PACKAGES=()
    for package in "${MAC_PACKAGES[@]}"; do
        if ! brew list "$package" > /dev/null 2>&1; then
            MISSING_PACKAGES+=("$package")
        fi
    done
    if [ ${#MISSING_PACKAGES[@]} -gt 0 ]; then
        brew install "${MISSING_PACKAGES[@]}"
    fi

else
    LINUX_PACKAGES=(
        build-essential
        git
        ca-certificates
        curl
        zsh
    )
    sudo apt-get update
    sudo apt-get -y dist-upgrade
    MISSING_PACKAGES=()
    for package in "${LINUX_PACKAGES[@]}"; do
        if ! dpkg-query -W -f='${Status}' "$package" 2>/dev/null | grep -q "install ok installed"; then
            MISSING_PACKAGES+=("$package")
        fi
    done
    if [ ${#MISSING_PACKAGES[@]} -gt 0 ]; then
        sudo apt-get install -y "${MISSING_PACKAGES[@]}"
    fi
    # Install SDKMAN
    if ! [ -d "$HOME/.sdkman" ]; then
        curl -s "https://get.sdkman.io" | bash
    fi

    # Install Conda and Mamba
    MINICONDA_DIR="$HOME/miniconda3"
    if [ ! -d "$MINICONDA_DIR" ]; then
        echo "Conda not found, installing Miniconda..."
        MINICONDA_INSTALLER="$HOME/tmp/miniconda.sh"
        mkdir -p "$HOME/tmp"
        curl -fsSL "https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh" -o "$MINICONDA_INSTALLER"
        bash "$MINICONDA_INSTALLER" -b -p "$MINICONDA_DIR"
        rm -f "$MINICONDA_INSTALLER"
    fi

    # Setup conda in PATH for current script
    export PATH="$MINICONDA_DIR/bin:$PATH"

    # Install Mamba only if not already present
    if ! "$MINICONDA_DIR/bin/mamba" --version > /dev/null 2>&1; then
        echo "Mamba not found, installing via conda..."
        export CONDA_ALWAYS_YES=true
        export CONDA_AUTO_ACTIVATE_BASE=false
        # Accept conda TOS for default channels
        "$MINICONDA_DIR/bin/conda" tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main || true
        "$MINICONDA_DIR/bin/conda" tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r || true
        CONDA_SUBSHELL=true "$MINICONDA_DIR/bin/conda" install -n base -c conda-forge mamba
    fi

    # Install docker
    if ! [ "$(command -v docker)" ]; then
        sudo install -m 0755 -d /etc/apt/keyrings
        sudo curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
        sudo chmod a+r /etc/apt/keyrings/docker.asc
        echo \
            "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu \
            $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | \
        sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
        sudo apt-get update
        sudo apt-get install -y \
            docker-ce \
            docker-ce-cli \
            containerd.io \
            docker-buildx-plugin \
            docker-compose-plugin \

        # Configure Docker
        sudo usermod -aG docker $USER
        sudo systemctl enable docker
        sudo systemctl start docker
    fi
    if ! snap list | grep -q code; then
        sudo snap install --classic code
    fi
    if ! snap list | grep -q intellij-idea-community; then
        sudo snap install --classic intellij-idea-community
    fi
    if ! [ "$(command -v google-chrome)" ]; then
        wget -q -O - https://dl.google.com/linux/linux_signing_key.pub | sudo apt-key add -
        echo "deb [arch=amd64] http://dl.google.com/linux/chrome/deb/ stable main" | sudo tee /etc/apt/sources.list.d/google-chrome.list
        sudo apt update
        sudo apt install -y google-chrome-stable
    fi

    # Install nvm
    if ! [ -s "$HOME/.nvm/nvm.sh" ]; then
        curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash
    fi

    # Install CUDA Toolkit
    if ! command -v nvcc > /dev/null 2>&1; then
        echo "CUDA Toolkit not found, installing..."
        CUDA_VERSION=12-2
        CUDA_DISTRO="ubuntu$(. /etc/os-release && echo "${VERSION_ID//./}")"
        CUDA_KEYRING=/etc/apt/keyrings/cuda-archive-keyring.gpg
        CUDA_APT_LIST=/etc/apt/sources.list.d/cuda.list

        sudo mkdir -p /etc/apt/keyrings
        if [ ! -f "$CUDA_APT_LIST" ]; then
            curl -fsSL "https://developer.download.nvidia.com/compute/cuda/repos/${CUDA_DISTRO}/x86_64/3bf863cc.pub" | sudo gpg --dearmor -o "$CUDA_KEYRING"
            echo "deb [signed-by=$CUDA_KEYRING] https://developer.download.nvidia.com/compute/cuda/repos/${CUDA_DISTRO}/x86_64/ /" | sudo tee "$CUDA_APT_LIST" > /dev/null
        fi
        sudo apt-get update

        CUDA_PACKAGES=(
            "cuda-toolkit-${CUDA_VERSION}"
            "cuda-${CUDA_VERSION}"
            "cuda-toolkit"
            "cuda"
        )
        for pkg in "${CUDA_PACKAGES[@]}"; do
            if sudo apt-get install -y "$pkg"; then
                break
            fi
        done
    fi

    # Install CMake 4.0 or higher
    if ! command -v cmake > /dev/null 2>&1; then
        echo "CMake not found, installing..."
        ARCH=$(uname -m)
        CMAKE_VERSION="4.3.3"
        CMAKE_INSTALLER="$HOME/tmp/cmake-${CMAKE_VERSION}-linux-${ARCH}.sh"
        mkdir -p "$HOME/tmp"
        curl -fsSL "https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}-linux-${ARCH}.sh" -o "$CMAKE_INSTALLER"
        bash "$CMAKE_INSTALLER" --skip-license --prefix="$HOME/.local"
        rm -f "$CMAKE_INSTALLER"
        export PATH="$HOME/.local/bin:$PATH"
    fi

fi


# Download ohia files
if ! [ -d "$OHIA_HOME" ]; then
    mkdir -p "$PROJECT_HOME"
    cd "$PROJECT_HOME"
    git clone https://github.com/imotov/ohia.git
    cd "$OHIA_HOME"
    git remote set-url origin git@github.com:imotov/ohia.git
else
    cd "$OHIA_HOME"
fi

# Install oh-my-zsh
if ! [ -d "$HOME/.oh-my-zsh" ]; then
    git clone -q https://github.com/ohmyzsh/ohmyzsh.git "$HOME/.oh-my-zsh"
    cp "$OHIA_HOME/zshrc/zshrc" "$HOME/.zshrc"
fi

# Copy configuration files
if [ $OS = "Darwin" ]; then
    rsync -u "$OHIA_HOME/zshrc/zshrc" "$HOME/.zshrc"
    rsync -u "$OHIA_HOME/gitconfig/gitconfig.osx" "$HOME/.gitconfig"
    rsync -ur "$OHIA_HOME/oh-my-zsh/custom/" "$HOME/.oh-my-zsh/custom/"
else
    cp -u "$OHIA_HOME/zshrc/zshrc" "$HOME/.zshrc"
    cp -u "$OHIA_HOME/gitconfig/gitconfig" "$HOME/.gitconfig"
    cp -ur "$OHIA_HOME/oh-my-zsh/custom" "$HOME/.oh-my-zsh/"
fi

cd "$OHIA_HOME"
